generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum DeliveryStatus {
  ARRIVED
  DELAYED
  SHIPPED
  PROCESSING
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  company   String?
  status    Status   @default(ACTIVE)
  deletedAt DateTime?
  shipments Shipment[]
}

model Shipment {
  id             Int            @id @default(autoincrement())
  trackingNumber String
  customer       Customer?      @relation(fields: [customerId], references: [id])
  customerId     Int?
  origin         String
  destination    String
  status         DeliveryStatus @default(PROCESSING)
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages  ChatMessage[]
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId Int
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}